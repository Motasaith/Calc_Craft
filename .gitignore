# Ignore everything inside /scripts except the chatbot/search data aggregator
# (which must be committed so it runs on Cloudflare Pages builds and
# generates public/site-index.json). Note: git cannot re-include a file
# whose parent DIR is excluded, so we exclude /scripts/* (contents) not
# /scripts (the dir itself).
/scripts/*
!/scripts/build-site-index.ts